{
  "name": "mycelium",
  "version": "1.0.0",
  "description": "Mycelium CLI — AI 智能体网文创作工具",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mycelium": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "dev": "tsx --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {},
  "keywords": [
    "mycelium",
    "ai",
    "agent",
    "novel",
    "web-fiction",
    "creative-writing",
    "cli"
  ],
  "author": "oxroot <oxrootnsexypig@gmail.com> (https://github.com/oxroot-crypto)",
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ]
}

{
  /* ========================================================================
   * TypeScript 基础配置 — 所有子包 extend 此文件
   * ======================================================================== */
  "compilerOptions": {
    /* ---- 编译目标 ---- */
    // Node 22 完整支持 ES2022（Top-level await、Class fields、Array.at 等）
    "target": "ES2022",

    /* ---- 模块系统 ---- */
    // Node.js 原生 ESM 输出格式
    "module": "NodeNext",
    // NodeNext 解析策略：与 module: NodeNext 配套，支持 .js 扩展名自动解析
    "moduleResolution": "NodeNext",

    /* ---- 输出 ---- */
    // 生成 .d.ts 类型声明文件，供下游使用
    "declaration": true,
    // 生成 .d.ts.map，IDE "Go to Definition" 跳转到源码而非类型
    "declarationMap": true,
    // 生成 .js.map，调试时映射回 TypeScript 源码
    "sourceMap": true,
    // 启用增量编译（生成 .tsbuildinfo），配合 project references 加速构建
    "composite": true,

    /* ---- 严格模式 ---- */
    // 启用所有严格类型检查选项
    "strict": true,
    // 允许 CommonJS 模块的默认导入（兼容过渡期）
    "esModuleInterop": true,
    // 跳过 node_modules 类型检查，加速编译
    "skipLibCheck": true,
    // 强制文件名大小写一致（避免 macOS/Windows 差异导致的 CI 失败）
    "forceConsistentCasingInFileNames": true,
    // 允许导入 JSON 文件并推断类型
    "resolveJsonModule": true,
    // 确保每个文件都可安全地独立编译（tsc --build 要求）
    "isolatedModules": true,

    // 开发模式下优先解析 exports 中的 development 条件（指向源码 .ts）
    "customConditions": ["development"],

    // 允许导入 .ts 扩展名的模块（配合 NodeNext 解析策略）
    "allowImportingTsExtensions": true,
    // 将相对导入的扩展名从 .ts 改为 .js（配合 NodeNext 输出）
    "rewriteRelativeImportExtensions": true
  }
}

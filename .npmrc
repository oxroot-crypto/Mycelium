# ============================================================================
# pnpm 运行时配置
# 详见: https://pnpm.io/npmrc
# ============================================================================

# 不提升依赖到根 node_modules（严格隔离，避免幽灵依赖）
shamefully-hoist=false

# 缺少 peer dependencies 时报错（而非静默忽略）
strict-peer-dependencies=true

# 自动安装缺失的 peer dependencies
auto-install-peers=true

# workspace 包通过符号链接深度链接（而非拷贝）
link-workspace-packages=deep

# engines 不匹配时报错而非警告
engine-strict=true

{
  "name": "@mycelium/tui",
  "version": "1.0.0",
  "description": "Mycelium 终端交互界面 — 对标 Claude Code 的沉浸式 TUI 体验",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "typecheck": "tsc --noEmit",
    "dev": "tsx --watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@mycelium/core": "workspace:*",
    "@mycelium/orchestrator": "workspace:*"
  },
  "author": "oxroot <oxrootnsexypig@gmail.com> (https://github.com/oxroot-crypto)",
  "license": "MIT",
  "files": [
    "dist"
  ]
}
